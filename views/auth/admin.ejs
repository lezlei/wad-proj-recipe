<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
</head>
<body>
    <h1>Digital Recipe Box - Admin Dashboard</h1>

    <p><a href="/">Back to Home</a></p>
    
    <table border="1">
        <tr>
            <th>User ID</th>
            <th>Username</th>
            <th>Email</th>
            <th>Status</th>
            <th>Current Role</th>
            <th>Promote / Demote</th>
            <th>Account Access</th>
            <th>Deletion</th>
        </tr>
        <% for (let user of users) { %>
            <tr>
                <td><%= user._id %></td>
                <td><strong><%= user.username %></strong></td>
                <td><%= user.email %></td>
                
                <td>
                    <% if (user.isSuspended) { %>
                        Banned
                    <% } else { %>
                        Active
                    <% } %>
                </td>
                
                <td><%= user.role %></td>
                
                <td>
                    <form action="/auth/update-role" method="POST" style="margin: 0;">
                        <input type="hidden" name="id" value="<%= user._id %>">
                        <select name="role">
                            <option value="user" <%= user.role === 'user' ? 'selected' : '' %>>User</option>
                            <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Admin</option>
                        </select>
                        <button type="submit" class="btn-save">Save</button>
                    </form>
                </td>

                <td>
                    <% let action = user.isSuspended ? 'unban' : 'ban'; %>
                    <form action="/auth/toggle-suspend" method="POST"
                          onsubmit="return confirm('Are you sure you want to <%= action %> this user?');">
                        <input type="hidden" name="id" value="<%= user._id %>">
                        
                        <% if (user.isSuspended) { %>
                            <button type="submit">Unban User</button>
                        <% } else { %>
                            <button type="submit">Ban User</button>
                        <% } %>
                    </form>
                </td>
                <td>
                    <form action="/auth/delete" method="POST"
                          onsubmit="return confirm('Are you sure you want to delete this user?')">
                        <input type="hidden" name="id" value="<%= user._id %>">
                        <button type="submit">Delete</button>
                    </form>
                </td>
            </tr>
        <% } %>
    </table>

    <p>
        <h2>Post New System Announcement</h2>
            <form action="/auth/announcement" method="POST">
                <textarea rows="5" cols="50" name="msg" placeholder="Type your announcement here..." required></textarea><br>
                <button type="submit">Publish to Site</button>
            </form>
            <form action="/auth/deactivate-banner" method="POST">
                <button type="submit">Turn Off Banner</button>
            </form>
    </p>
    <p>
        <% if (message) { %>
            <h3><%= message %></h3>
        <% } %>
    </p>

</body>
</html>