
<nav style="position: sticky; top: 0; background: white; padding: 10px 20px; border-bottom: 1px solid #ccc; z-index: 1000; display: flex; align-items: center; justify-content: space-between;">
  
  <div style="flex: 1;">
    <a href="/">Back to Home</a>
  </div>

  <div style="flex: 2; text-align: center;">
    <a href="#my-recipes" >My Recipes</a> |
    <a href="#my-favourites">My Favourites</a> |
    <a href="#more-recipes">More Recipes You May Like</a> |
    <a href="#top-rated">Top Rated Recipes</a> |
    <a href="#all-recipes">All Recipes</a>
  </div>

  <div style="flex: 1;"></div>
</nav>
<br>

<% if (banner && banner.isActive) { %>
    <div style="background: yellow; padding: 1px; text-align: center;">
        <h3><%= banner.content %></h3>
    </div>
<% } %>

<h1 align="center"><u>Recipes</u></h1>

<div align="center">
<span id="my-recipes" style="display: block; position: relative; top: -60px; visibility: hidden;"></span>  

<h2>My Recipes</h2>

<table border="1">

  <style>

    td {
        padding-top: 5px;
        padding-bottom: 5px;
        padding-left: 15px; 
        padding-right: 15px;
        }

  </style>

  <thead>
    <tr>

      <th>Title</th>
      <th>Cuisine</th>
      <th>Description</th>
      <th>Ingredients</th>
      <th>Instructions</th>
      <th>Reviews</th>
      <% if (myRecipes.length > 0) { %>
        <th colspan="2">Actions</th> 
      <% } %>     

    </tr>
  </thead>

  <tbody>
    <% if (myRecipes.length === 0) { %>
      <tr>
        <td colspan="6">You have not created any recipes yet.</td>
      </tr>
    <% } else { %>
      <% myRecipes.forEach(recipe => { %>
        <tr>

          <td>
            <%= recipe.title %>
          </td>

          <td><%= recipe.cuisine %></td>

          <td><%= recipe.description %></td>

          <td>  
            <ul>
              <% recipe.ingredients.forEach(ing => { %>
                <li><%= ing %></li>
              <% }) %>
            </ul>
          </td>

          <td>
            <ol>
              <% recipe.instructions.forEach(ins => { %>
                <li><%= ins %></li>
              <% }) %>
            </ol>
          </td>

          <td>
            <a href="/reviews?recipeId=<%= recipe._id %>">View Reviews</a> <br>
            Avg Rating: <%= recipe.avgScore.toFixed(2) %> / 5 <br>
            Reviews: <%= recipe.reviewCount %>
          </td>
          
          <td>
            <a href="/recipes/<%= recipe._id %>/edit">Edit</a>
          </td>
        

          <td>
            <form action="/recipes/<%= recipe._id %>/delete" method="POST" style="display:inline;">
              <button type="submit" style="background-color: red; color: white;" onclick="return confirm('Are you sure you want to delete this recipe?');">Delete</button>
            </form>
          </td>
          
        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>

<br>

<a href="/recipes/create">+ Create New Recipe</a>

</div>

<div align='center'>
<span id="my-favourites" style="display: block; position: relative; top: -60px; visibility: hidden;"></span>

<h2>My Favourites</h2>

<table border="1">

  <style>

    td {
      padding-top: 5px;
      padding-bottom: 5px;
      padding-left: 15px;
      padding-right: 15px;
    }

  </style>

  <thead>

    <tr>
      <th>Title</th>
      <th>Cuisine</th>
      <th>Description</th>
      <th>Ingredients</th>
      <th>Instructions</th>
      <th>Author</th>
      <th>Reviews</th>
    <% if (favRecipes.length > 0) { %>
        <th colspan="2">Actions</th>
    <% } %>
    </tr>

  </thead>

  <tbody>

    <% if (favRecipes.length === 0) { %>
      <tr>
        <td colspan="7">You have not added any favourites yet.</td>
      </tr>
    <% } else { %>
      <% favRecipes.forEach(recipe => { %>
        <tr>

          <td>
            <%= recipe.title %>
          </td>

          <td><%= recipe.cuisine %></td>

          <td><%= recipe.description %></td>

          <td>
            <ul>
              <% recipe.ingredients.forEach(ing => { %>
                <li><%= ing %></li>
              <% }) %>
            </ul>
          </td>

          <td>
            <ol>
              <% recipe.instructions.forEach(ins => { %>
                <li><%= ins %></li>
              <% }) %>
            </ol>
          </td>

          <td><%= recipe.authorID ? recipe.authorID.username : 'Unknown' %></td>

          <td>
            <a href="/reviews?recipeId=<%= recipe._id %>">View Reviews</a> <br>
            Avg Rating: <%= recipe.avgScore ? recipe.avgScore.toFixed(2) : 'N/A' %> / 5 <br>
            Reviews: <%= recipe.reviewCount %>
          </td>

          <td>
            <form action="/favourites/<%= recipe._id %>/delete" method="POST" style="display:inline;" >
              <button type="submit" style="background-color: red; color: white;" onclick="return confirm('Are you sure you want to remove this recipe from favourites?');">Remove</button>
            </form>
          </td>

        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>

</div>


<br><br><hr><br><br>

<div align="center">
<span id="more-recipes" style="display: block; position: relative; top: -60px; visibility: hidden;"></span>

<h2>More Recipes You May Like</h2>
<p><em>Based on your favourites!</em></p>

<table border="1">
  <thead>
    <tr>
      <th>Title</th>
      <th>Cuisine</th>
      <th>Description</th>
      <th>Author</th>
      <th>Reviews</th>
      <th colspan="1">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (recommendedRecipes.length === 0) { %>
      <tr>
        <td colspan="6">No recommendations available at the moment. Add more favourites!</td>
      </tr>
    <% } else { %>
      <% recommendedRecipes.forEach(recipe => { %>
        <tr>
          <td><%= recipe.title %></td>
          <td><%= recipe.cuisine %></td>
          <td><%= recipe.description %></td>
          <td><%= recipe.authorID ? recipe.authorID.username : 'Unknown' %></td>
          <td>
            <a href="/reviews?recipeId=<%= recipe._id %>">View Reviews</a><br>
            Avg Rating: <%= recipe.avgScore ? recipe.avgScore.toFixed(2) : '0.00' %> / 5<br>
            Reviews: <%= recipe.reviewCount %>
          </td>
          <td>
            <form action="/recipes/<%= recipe._id %>/favourite" method="POST" style="display:inline;">
              <button type="submit">Add to Favourites</button>
            </form>
          </td>
        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>
</div>


<br><br><hr><br><br>

<div align="center">
<span id="top-rated" style="display: block; position: relative; top: -60px; visibility: hidden;"></span>

<h2>Top Rated Recipes 🏆</h2>

<table border="1" width="100%" cellpadding="20" cellspacing="0" style="border-collapse: collapse; font-family: sans-serif;">
  <tr align="center" valign="bottom">
    
    <td width="33%" bgcolor="#f2f2f2">
      <h2 style="margin: 0; color: #7f8c8d;">2nd Place</h2>
      <hr>
      <% if (topRated[1]) { %>
        <small><%= topRated[1].cuisine %></small>
        <h3><%= topRated[1].title %></h3>
        <p>⭐ <%= topRated[1].avgScore.toFixed(1) %></p>
        <a href="/recipes/<%= topRated[1]._id %>">View Recipe</a>
      <% } else { %>
        <p>No entry</p>
      <% } %>
    </td>

    <td width="34%" bgcolor="#fffdf0" style="border: 3px solid #f1c40f;">
      <h1 style="margin: 0; color: #d4af37;">1st Place 👑</h1>
      <hr>
      <% if (topRated[0]) { %>
        <small><b><%= topRated[0].cuisine %></b></small>
        <h2><%= topRated[0].title %></h2>
        <p style="font-size: 1.2em;"><b>⭐ <%= topRated[0].avgScore.toFixed(1) %></b></p>
        <p><i>"<%= topRated[0].description.substring(0, 50) %>..."</i></p>
        <a href="/recipes/<%= topRated[0]._id %>"><b>VIEW RECIPE</b></a>
      <% } else { %>
        <p>No entry</p>
      <% } %>
    </td>

    <td width="33%" bgcolor="#fdf5f0">
      <h2 style="margin: 0; color: #cd7f32;">3rd Place</h2>
      <hr>
      <% if (topRated[2]) { %>
        <small><%= topRated[2].cuisine %></small>
        <h3><%= topRated[2].title %></h3>
        <p>⭐ <%= topRated[2].avgScore.toFixed(1) %></p>
        <a href="/recipes/<%= topRated[2]._id %>">View Recipe</a>
      <% } else { %>
        <p>No entry</p>
      <% } %>
    </td>

  </tr>
</table>

</div>

<br><br><hr><br><br>

<div align="center">
<span id="all-recipes" style="display: block; position: relative; top: -60px; visibility: hidden;"></span>

<h2>All Recipes</h2>

<form action="/recipes" method="get" align="center">
  <input type="text" name="search" placeholder="Search recipes..." value="<%= search || '' %>">

  <select name="filter">
    <option value="title" <%= filter === 'title' ? 'selected' : '' %>>By Title</option>
    <option value="author" <%= filter === 'author' ? 'selected' : '' %>>By Author</option>
    <option value="ingredients" <%= filter === 'ingredients' ? 'selected' : '' %>>By Ingredients</option>
    <option value="cuisine" <%= filter === 'cuisine' ? 'selected' : '' %>>By Cuisine</option>
  </select>

  <button type="submit">Search</button>
  <% if (search) { %>
    <a href="/recipes#all-recipes">Clear</a>
  <% } %>
</form>

<div align="center">
  <a href="/recipes/recommendation">Don't know what to eat? Click Me!</a> <br><br>
  <table border="1">

  <thead>

    <tr>

      <th>Title</th>
      <th>Cuisine</th>
      <th>Description</th>
      <th>Ingredients</th>
      <th>Instructions</th>
      <th>Author</th>
      <th>Reviews</th>
      <% if (user.role === 'admin'){ %>
        <th colspan="2">Actions</th>
      <% } %>
    </tr>

  </thead>

  <tbody>

    <% if (allRecipes.length === 0) { %>
      <tr>
        <td colspan="7">No recipes found.</td>
      </tr>
    <% } else { %>
      <% allRecipes.forEach(recipe => { %>
        <tr>

          <td><%= recipe.title %></td>

          <td><%= recipe.cuisine %></td>

          <td><%= recipe.description %></td>
          
          <td>
            <ul>
              <% recipe.ingredients.forEach(ing => { %>
                <li><%= ing %></li>
              <% }) %>
            </ul>
          </td>

          <td>
            <ol>
              <% recipe.instructions.forEach(ins => { %>
                <li><%= ins %></li>
              <% }) %>
            </ol>
          </td>

          <td><%= recipe.authorID ? recipe.authorID.username : 'Unknown' %></td>
          
          <td>
            <a href="/reviews?recipeId=<%= recipe._id %>">View Reviews</a>
            <br>
            Avg Rating: <%= recipe.avgScore.toFixed(2) %> / 5
            <br>
            Reviews: <%= recipe.reviewCount %>
            <br><br>

            <% 
              const isFavourited = favRecipes.some(fav => String(fav._id) === String(recipe._id)); 
            %>

            <% if (recipe.authorID && user && String(recipe.authorID._id) !== String(user._id) && !isFavourited) { %>
              <form action="/recipes/<%= recipe._id %>/favourite" method="POST" style="display:inline;">
                <button type="submit">Add to Favourites</button>
              </form>
            <% } else if (isFavourited) { %>
              Favourited ★
            <% } %>
          </td>
          
          <% if (user && user.role === 'admin') { %>
            <td>
              <a href="/recipes/<%= recipe._id %>/edit">Edit</a>
            </td>

            <td>
              <form action="/recipes/<%= recipe._id %>/delete" method="POST" style="display:inline;">
                <button type="submit" style="background-color: red; color: white;" onclick="return confirm('Are you sure you want to delete this recipe?');">Delete</button>
              </form>
            </td>
          <% } %>
        </tr>
      <% }) %>
    <% } %>

  </tbody>
</table>

</div>  