<h2>Add Review</h2>

<form action="/reviews" method="POST">

  <input type="hidden" name="recipeId" value="<%= recipeId %>">

  <div>
    <label><strong>Rating (1-5):</strong></label><br>
    <input type="number" name="rating" min="1" max="5" required style="width:60px;">
  </div>

  <br>

  <div>
    <label><strong>Comment:</strong></label><br>
    <textarea name="comment" rows="4" cols="40" required></textarea>
  </div>

  <br>

  <button type="submit">Submit Review</button>

  <br><br>

  <a href="/recipes">Back to Recipes</a>

</form>

<hr>

<h2>Reviews</h2>

<table border="1">
  <thead>
    <tr>
      <th>User</th>
      <th>Rating</th>
      <th>Comment</th>
      <% reviews.forEach(review => { %>
        <% if (review.user && (review.user._id.toString() === String(userId) || role === "admin")) { %>
          <th colspan="2">Actions</th>
        <% } %>
      <% }) %>
    </tr>
  </thead>

  <tbody>

    <% if (reviews.length === 0) { %>
      <tr>
        <td colspan="4">No reviews yet.</td>
      </tr>
    <% } else { %>

      <% reviews.forEach(review => { %>

        <tr>
          <td><%= review.user ? review.user.username : "User" %></td>
          <td><%= review.rating %></td>
          <td><%= review.comment %></td>

          
            <% if (review.user && (review.user._id.toString() === String(userId) || role === "admin")) { %>
              <!-- UPDATE -->
              <td>
                <form action="/reviews/edit" method="GET" style="display:inline;">
                  <input type="hidden" name="reviewId" value="<%= review._id %>">
                  <button type="submit">Update</button>
                </form>
              </td>
              <!-- DELETE -->
              <td>
                <form action="/reviews/delete" method="POST" style="display:inline;">
                  <input type="hidden" name="reviewId" value="<%= review._id %>">
                  <button type="submit">Delete</button>
                </form>
              </td>
            <% } %>
          
        </tr>

      <% }) %>

    <% } %>

  </tbody>
</table>