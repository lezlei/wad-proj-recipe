
<h2>Add Review</h2>
<i>Share your thoughts on this recipe with others!</i>
<br><br>

<form action="/reviews" method="POST">
  <input type="hidden" name="recipeId" value="<%= recipeId %>">

  <div>
    <label><strong>Rating (1-5) ⭐️: </strong></label><br>
    <input type="number" name="rating" min="1" max="5" required style="width:60px;">
  </div>

  <br>

  <div>
    <label><strong>Comment:</strong></label><br>
    <textarea name="comment" rows="4" cols="40" required></textarea>
  </div>

  <br>

  <button type="submit">Submit Review</button>

  <br><br>

  <a href="/recipes">Back to Recipes</a>
</form>

<hr>

<h2>Reviews</h2>

<% if (role === "admin" && reviews.length > 0) { %>
  <form action="/reviews/delete-all" method="POST" onsubmit="return confirm('Are you sure you want to delete ALL reviews?');">
    <input type="hidden" name="recipeId" value="<%= recipeId %>">
    <button type="submit" style="background-color:red; color:white;">
      Delete All Reviews
    </button>
  </form>
  <br>
<% } %>

<% if (deleted) { %>
  <p style="color:green;">All reviews deleted successfully.</p>
<% } %>

<table border="1">
  <thead>
    <tr>
      <th>User</th>
      <th>Rating</th>
      <th>Comment</th>
      <th>Votes</th>
      <th colspan="2">Actions</th>
      <th>Replies</th> <!-- ✅ NEW COLUMN -->
    </tr>
  </thead>

  <tbody>

    <% if (reviews.length === 0) { %>
      <tr>
        <td colspan="7">No reviews yet.</td>
      </tr>
    <% } else { %>

      <% reviews.forEach(review => { %>

        <!-- MAIN REVIEW ROW -->
        <tr>
          <td><%= review.user ? review.user.username : "User" %></td>
          <td><%= review.rating %></td>
          <td><%= review.comment %></td>

          <!-- VOTES -->
          <td>
            <form action="/reviews/vote" method="POST" style="display:inline;">
              <input type="hidden" name="reviewId" value="<%= review._id %>">
              <input type="hidden" name="value" value="1">
              <button type="submit">👍</button>
            </form>

            <form action="/reviews/vote" method="POST" style="display:inline;">
              <input type="hidden" name="reviewId" value="<%= review._id %>">
              <input type="hidden" name="value" value="-1">
              <button type="submit">👎</button>
            </form>

            <br>

            👍 <%= (review.votes || []).filter(v => v.value === 1).length %>
            👎 <%= (review.votes || []).filter(v => v.value === -1).length %>
          </td>

          <!-- ACTIONS -->
          <% if (review.user && (review.user._id.toString() === String(userId) || role === "admin")) { %>
            <td>
              <form action="/reviews/edit" method="GET">
                <input type="hidden" name="reviewId" value="<%= review._id %>">
                <button type="submit">Update</button>
              </form>
            </td>

            <td>
              <form action="/reviews/delete" method="POST">
                <input type="hidden" name="reviewId" value="<%= review._id %>">
                <button type="submit">Delete</button>
              </form>
            </td>
          <% } else { %>
            <td colspan="2">None</td>
          <% } %>

          <!-- ✅ REPLIES BUTTON -->
          <td>
            <button type="button" onclick="toggleReplies('<%= review._id %>')">
              Replies (<%= (review.replies || []).length %>)
            </button>
          </td>
        </tr>

        <!-- ✅ HIDDEN REPLIES ROW -->
        <tr id="replies-<%= review._id %>" style="display:none;">
          <td colspan="7">

            <% if (!review.replies || review.replies.length === 0) { %>
              <p>No replies yet.</p>
            <% } else { %>

              <% review.replies.forEach(reply => { %>
                <div style="margin-left:20px; border-left:2px solid #ccc; padding-left:10px; margin-bottom:10px;">
                  
                  <strong><%= reply.user ? reply.user.username : "User" %></strong><br>
                  <small><%= new Date(reply.createdAt).toLocaleString() %></small>
                  <p><%= reply.comment %></p>

                  <!-- ✅ DELETE REPLY BUTTON -->
                  <% if (reply.user && (reply.user._id.toString() === String(userId) || role === "admin")) { %>
                    <form action="/reviews/reply/delete" method="POST" style="display:inline;">
                      <input type="hidden" name="reviewId" value="<%= review._id %>">
                      <input type="hidden" name="replyId" value="<%= reply._id %>">
                      <button type="submit">Delete Reply</button>
                    </form>
                  <% } %>
                </div>
              <% }) %>
            <% } %>

            <!-- ✅ REPLY FORM -->
            <% if (userId) { %>
              <form action="/reviews/reply" method="POST">
                <input type="hidden" name="reviewId" value="<%= review._id %>">
                <input type="text" name="comment" placeholder="Write a reply..." required>
                <button type="submit">Reply</button>
              </form>
            <% } %>

          </td>
        </tr>

      <% }) %>

    <% } %>

  </tbody>
</table>

<!-- ✅ TOGGLE SCRIPT -->
<script>
function toggleReplies(id) {
  const row = document.getElementById("replies-" + id);
  row.style.display = row.style.display === "none" ? "table-row" : "none";
}
</script>
